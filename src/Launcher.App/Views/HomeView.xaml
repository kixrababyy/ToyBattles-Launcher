<UserControl x:Class="Launcher.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Launcher.App.Converters"
             Background="Transparent"
             Loaded="HomeView_Loaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="RootGrid"
                                Storyboard.TargetProperty="Margin"
                                From="0,20,0,-20" To="0"
                                Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Opacity="0">

        <!-- ===== BANNER IMAGE (positioned at the dark gradient edge) ===== -->
        <Image x:Name="BannerImage"
               MaxHeight="360" HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed"
               Margin="36,0,0,30"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TranslateTransform Y="0"/>
            </Image.RenderTransform>
            <Image.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                  Color="#26C0F0" Opacity="0.18"/>
            </Image.Effect>
            <Image.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                From="-4" To="4" Duration="0:0:3">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Image.Triggers>
        </Image>

        <!-- ===== BOTTOM OVERLAY: Game info + Play ===== -->
        <Grid VerticalAlignment="Bottom" Margin="36,0,36,32">
            <Grid.RowDefinitions>
                <!-- Progress bar (conditional) -->
                <RowDefinition Height="Auto"/>
                <!-- Main bottom bar -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Progress section — animated download card -->
            <Border x:Name="ProgressPanel" Grid.Row="0"
                    Background="#C0080D14" CornerRadius="14"
                    BorderBrush="#2026C0F0" BorderThickness="1"
                    Padding="20,16" Margin="0,0,0,18"
                    Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0" To="1" Duration="0:0:0.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                From="20" To="0" Duration="0:0:0.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                To="0" Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <!-- Status + speed + ETA row -->
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <!-- Pulsing activity dot -->
                            <Ellipse Width="8" Height="8" Margin="0,0,10,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{StaticResource AccentBlue}"/>
                                </Ellipse.Fill>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.4" To="1.0"
                                                                 Duration="0:0:0.8">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding DownloadSpeed}"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,16,0"
                                       Visibility="{Binding DownloadSpeed, Converter={StaticResource StringToVis}}"/>
                            <TextBlock Text="{Binding Eta}"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Visibility="{Binding Eta, Converter={StaticResource StringToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Progress bar -->
                    <ProgressBar Value="{Binding ProgressPercent}"
                                 Minimum="0" Maximum="100"
                                 Style="{StaticResource AccentProgressBar}"/>

                    <!-- Percentage text -->
                    <TextBlock FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,6,0,0">
                        <TextBlock.Text>
                            <Binding Path="ProgressPercent" StringFormat="{}{0:F1}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Main bottom bar: title left, PLAY right -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: version badges + status -->
                <StackPanel Grid.Column="0" VerticalAlignment="Bottom">

                    <!-- Text fallback (shown when no banner.png) -->
                    <StackPanel x:Name="BannerTextFallback">
                        <TextBlock FontSize="40" FontWeight="ExtraBold"
                                   FontFamily="Segoe UI" LineHeight="44">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                                  Color="#26C0F0" Opacity="0.18"/>
                            </TextBlock.Effect>
                            <Run Text="TOY" Foreground="{StaticResource AccentBlueBrush}"/>
                            <Run Text="BATTLES" Foreground="{StaticResource AccentGoldBrush}"/>
                        </TextBlock>
                        <TextBlock Text="MicroVolts Recharged"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#3A4A6A"
                                   Margin="3,3,0,10"/>
                    </StackPanel>

                    <!-- Version badges -->
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#12FFAA00" CornerRadius="5" Padding="9,4"
                                Margin="0,0,6,0"
                                Visibility="{Binding InstalledVersionText, Converter={StaticResource StringToVis}}">
                            <TextBlock Text="{Binding InstalledVersionText}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}"/>
                        </Border>
                        <Border Background="#0AFFFFFF" CornerRadius="5" Padding="9,4"
                                Visibility="{Binding RemoteVersionText, Converter={StaticResource StringToVis}}">
                            <TextBlock Text="{Binding RemoteVersionText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Status text (when progress bar is hidden) -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="#2A3350"
                               Margin="2,10,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>

                <!-- Right: PLAY button -->
                <Button Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Content="{Binding ActionButtonText}"
                        Command="{Binding ActionCommand}"
                        IsEnabled="{Binding IsActionEnabled}"
                        Style="{StaticResource PlayButton}"
                        Margin="20,0,0,0"/>

            </Grid>
        </Grid>

        <!-- ===== LINKS (top-right quick links) ===== -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Orientation="Horizontal" Margin="0,16,36,0">
            <Button Content="Website"
                    Command="{Binding DataContext.NavigateNewsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8" FontSize="12"
                    Margin="0,0,8,0"/>
            <Button Content="Discord"
                    Command="{Binding DataContext.NavigateDiscordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8" FontSize="12"/>
        </StackPanel>

    </Grid>
</UserControl>
