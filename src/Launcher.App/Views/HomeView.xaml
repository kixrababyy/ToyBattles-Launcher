<UserControl x:Class="Launcher.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Launcher.App.Converters"
             Background="Transparent"
             Loaded="HomeView_Loaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="RootGrid"
                                Storyboard.TargetProperty="Margin"
                                From="0,20,0,-20" To="0"
                                Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Opacity="0">

        <!-- ===== BANNER IMAGE (positioned at the dark gradient edge) ===== -->
        <Image x:Name="BannerImage"
               MaxHeight="360" HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="Collapsed"
               Margin="36,0,0,30"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TranslateTransform Y="0"/>
            </Image.RenderTransform>
            <Image.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                  Color="#26C0F0" Opacity="0.18"/>
            </Image.Effect>
            <Image.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                From="-4" To="4" Duration="0:0:3">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Image.Triggers>
        </Image>

        <!-- ===== BOTTOM OVERLAY: Game info + Play ===== -->
        <Grid VerticalAlignment="Bottom" Margin="36,0,36,32">
            <Grid.RowDefinitions>
                <!-- Progress bar (conditional) -->
                <RowDefinition Height="Auto"/>
                <!-- Inline settings panel (conditional) -->
                <RowDefinition Height="Auto"/>
                <!-- Main bottom bar -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Progress section — animated download card -->
            <Border x:Name="ProgressPanel" Grid.Row="0"
                    Background="#C0080D14" CornerRadius="14"
                    BorderBrush="#2026C0F0" BorderThickness="1"
                    Padding="20,16" Margin="0,0,0,18"
                    Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Fade in -->
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0" To="1" Duration="0:0:0.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Slide up -->
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                From="24" To="0" Duration="0:0:0.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Scale bounce -->
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                From="0.97" To="1" Duration="0:0:0.45">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                From="0.97" To="1" Duration="0:0:0.45">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Fade out -->
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                To="0" Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Slide down -->
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                To="16" Duration="0:0:0.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Scale down -->
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                To="0.98" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                To="0.98" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <!-- Status + speed + ETA row -->
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <!-- Pulsing activity dot -->
                            <Ellipse Width="8" Height="8" Margin="0,0,10,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{StaticResource AccentBlue}"/>
                                </Ellipse.Fill>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.4" To="1.0"
                                                                 Duration="0:0:0.8">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding DownloadSpeed}"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,16,0"
                                       Visibility="{Binding DownloadSpeed, Converter={StaticResource StringToVis}}"/>
                            <TextBlock Text="{Binding Eta}"
                                       FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Visibility="{Binding Eta, Converter={StaticResource StringToVis}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Progress bar -->
                    <ProgressBar Value="{Binding ProgressPercent}"
                                 Minimum="0" Maximum="100"
                                 Style="{StaticResource AccentProgressBar}"/>

                    <!-- Percentage text -->
                    <TextBlock FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,6,0,0">
                        <TextBlock.Text>
                            <Binding Path="ProgressPercent" StringFormat="{}{0:F1}%"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ===== INLINE SETTINGS PANEL ===== -->
            <Border x:Name="SettingsPanel" Grid.Row="1"
                    Margin="0,0,0,14"
                    Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                             From="18" To="0" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                             To="12" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <!-- Inner card — DataContext switched to SettingsVM -->
                <Border Background="#C2080D14" CornerRadius="14"
                        BorderBrush="#2026C0F0" BorderThickness="1"
                        Padding="20,16"
                        DataContext="{Binding DataContext.SettingsVM, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <StackPanel>

                            <!-- ===== VERIFY & REPAIR SECTION ===== -->
                            <StackPanel DataContext="{Binding DataContext.RepairVM, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Margin="0,0,0,16">

                                <TextBlock Text="Verify &amp; Repair" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Check your game files for corruption or missing data."
                                           FontSize="12" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,12"/>

                                <!-- Status text -->
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="13" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>

                                <!-- Progress bar + current file (when repairing) -->
                                <StackPanel Visibility="{Binding IsRepairing, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,0,12">
                                    <ProgressBar Value="{Binding ProgressPercent}"
                                                 Minimum="0" Maximum="100"
                                                 Style="{StaticResource AccentProgressBar}"/>
                                    <TextBlock Text="{Binding CurrentFileText}"
                                               FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,5,0,0"
                                               Visibility="{Binding CurrentFileText, Converter={StaticResource StringToVis}}"/>
                                </StackPanel>

                                <!-- Results summary -->
                                <Border Visibility="{Binding ResultSummary, Converter={StaticResource StringToVis}}"
                                        Background="#0CFFFFFF"
                                        CornerRadius="10" Padding="14,12"
                                        Margin="0,0,0,12"
                                        BorderBrush="#0EFFFFFF" BorderThickness="1">
                                    <TextBlock Text="{Binding ResultSummary}"
                                               FontSize="13" FontFamily="Segoe UI"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" LineHeight="20"/>
                                </Border>

                                <!-- Action buttons -->
                                <WrapPanel>
                                    <Button Content="Verify &amp; Repair Files"
                                            Command="{Binding RepairCommand}"
                                            IsEnabled="{Binding IsRepairEnabled}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,8,6"/>
                                    <Button Content="Full Reinstall"
                                            Command="{Binding FullReinstallCommand}"
                                            IsEnabled="{Binding IsReinstallEnabled}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,6"/>
                                    <Button Content="Clear Cache"
                                            Command="{Binding ClearCacheCommand}"
                                            IsEnabled="{Binding IsRepairEnabled}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,6"/>
                                    <Button Content="Cancel"
                                            Command="{Binding CancelCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,0,6"
                                            Visibility="{Binding IsRepairing, Converter={StaticResource BoolToVis}}"/>
                                </WrapPanel>

                                <!-- Cache size feedback -->
                                <TextBlock Text="{Binding CacheSizeText}"
                                           FontSize="11" FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding CacheSizeText, Converter={StaticResource StringToVis}}"/>

                            </StackPanel>

                            <!-- ===== SETTINGS SECTION ===== -->
                            <Border Height="1" Background="#14FFFFFF" Margin="0,0,0,16"/>

                            <!-- GAME DIRECTORY -->
                            <TextBlock Text="GAME DIRECTORY" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding GameRootPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}" IsReadOnly="True"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                    <Button Content="Browse"
                                            Command="{Binding BrowseGameRootCommand}"
                                            Style="{StaticResource SecondaryButton}"/>
                                    <Button Content="Open Folder"
                                            Command="{Binding OpenGameFolderCommand}"
                                            Style="{StaticResource SecondaryButton}" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- BEHAVIOUR -->
                            <CheckBox IsChecked="{Binding KeepLauncherOpen}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      FontFamily="Segoe UI" FontSize="13"
                                      Margin="0,0,0,16"
                                      Content="Keep launcher open after launching game"/>

                            <!-- ACTIONS -->
                            <WrapPanel>
                                <Button Content="Open Logs" Command="{Binding OpenLogsFolderCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                <Button Content="Create Shortcut" Command="{Binding CreateShortcutCommand}"
                                        Style="{StaticResource SecondaryButton}"/>
                            </WrapPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Border>

            <!-- Main bottom bar: title left, PLAY right -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: version badges + status -->
                <StackPanel Grid.Column="0" VerticalAlignment="Bottom">

                    <!-- Text fallback (shown when no banner.png) -->
                    <StackPanel x:Name="BannerTextFallback">
                        <TextBlock FontSize="40" FontWeight="ExtraBold"
                                   FontFamily="Segoe UI" LineHeight="44">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                                  Color="#26C0F0" Opacity="0.18"/>
                            </TextBlock.Effect>
                            <Run Text="TOY" Foreground="{StaticResource AccentBlueBrush}"/>
                            <Run Text="BATTLES" Foreground="{StaticResource AccentGoldBrush}"/>
                        </TextBlock>
                        <TextBlock Text="ToyBattles"
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#3A4A6A"
                                   Margin="3,3,0,10"/>
                    </StackPanel>

                    <!-- Version badges + server selector -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="5" Padding="9,4"
                                Margin="0,0,6,0"
                                Visibility="{Binding InstalledVersionText, Converter={StaticResource StringToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#12FFAA00"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVersionUpToDate}" Value="True">
                                            <Setter Property="Background" Value="#182ECC71"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding InstalledVersionText}"
                                       FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVersionUpToDate}" Value="True">
                                                <Setter Property="Foreground" Value="#2ECC71"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border Background="#0AFFFFFF" CornerRadius="5" Padding="9,4"
                                Margin="0,0,6,0"
                                Visibility="{Binding RemoteVersionText, Converter={StaticResource StringToVis}}">
                            <TextBlock Text="{Binding RemoteVersionText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding ServerOptions}"
                                  SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="lockIcon"
                                                   Text="&#xE72E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="9"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0"
                                                   Visibility="Collapsed"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="Test Server">
                                            <Setter TargetName="lockIcon" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="10,7"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#1826C0F0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.3"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="Test Server">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="ToolTip" Value="Coming soon"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>

                    <!-- Status text (when progress bar is hidden) -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="#2A3350"
                               Margin="2,10,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProgressVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Bottom" Margin="20,0,0,0">

                    <!-- Download size estimate badge -->
                    <Border Background="#12FFAA00" CornerRadius="5" Padding="9,4"
                            VerticalAlignment="Center" Margin="0,0,10,0"
                            Visibility="{Binding DownloadSizeText, Converter={StaticResource StringToVis}}">
                        <TextBlock Text="{Binding DownloadSizeText}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGoldBrush}"/>
                    </Border>

                    <!-- Cancel button (visible during downloads) -->
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Padding="20,0" Height="54" FontSize="13"
                            Margin="0,0,10,0" VerticalAlignment="Bottom">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCancelVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Check for Updates button (visible when ready/error) -->
                    <Button Content="Check for Updates"
                            Command="{Binding CheckUpdatesCommand}"
                            Padding="20,0" Height="54" FontSize="13"
                            Margin="0,0,10,0" VerticalAlignment="Bottom">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCheckUpdatesVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Settings toggle button -->
                    <Button Command="{Binding ToggleSettingsCommand}"
                            Width="54" Height="54"
                            Margin="0,0,10,0" VerticalAlignment="Bottom"
                            Style="{StaticResource SecondaryButton}"
                            ToolTip="Settings &amp; Repair">
                        <TextBlock Text="&#xEA37;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Playtime badge above play button, centred on button axis -->
                    <Grid VerticalAlignment="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="#1AFFFFFF"
                                BorderBrush="#25FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18,10"
                                Margin="0,0,0,14"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE121;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="{Binding PlaytimeText}"
                                           FontSize="15" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Row="1"
                                Content="{Binding ActionButtonText}"
                                Command="{Binding ActionCommand}"
                                IsEnabled="{Binding IsActionEnabled}"
                                Style="{StaticResource PlayButton}"/>
                    </Grid>
                </StackPanel>

            </Grid>
        </Grid>

        <!-- ===== SERVER STATUS (bottom-left corner) ===== -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Orientation="Horizontal" Margin="36,0,0,10">
            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0"
                     Fill="{Binding ServerStatusBrush}"/>
            <TextBlock Text="{Binding ServerStatusText}"
                       FontSize="11" FontFamily="Segoe UI"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ===== LINKS (top-right quick links) ===== -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Orientation="Horizontal" Margin="0,16,36,0">
            <Button Command="{Binding DataContext.NavigateNewsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE128;"
                               FontFamily="Segoe MDL2 Assets" FontSize="11"
                               VerticalAlignment="Center" Margin="0,1,6,0"/>
                    <TextBlock Text="Website" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding DataContext.NavigateDiscordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource SecondaryButton}"
                    Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Path Width="24" Height="24" Stretch="Uniform"
                              Fill="{StaticResource TextPrimaryBrush}"
