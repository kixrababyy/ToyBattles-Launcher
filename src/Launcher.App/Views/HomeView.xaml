<UserControl x:Class="Launcher.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Launcher.App.Converters"
             Loaded="HomeView_Loaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <!-- Fade-in animation for page load -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="RootGrid"
                                Storyboard.TargetProperty="Margin"
                                From="0,20,0,0" To="0"
                                Duration="0:0:0.5"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== TOP CONTENT: Carousel (left) + Links (right) ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- ===== NEWS CAROUSEL (left side) ===== -->
            <Border Grid.Column="0" Margin="0,0,16,0"
                    Style="{StaticResource GlowCard}"
                    Padding="0"
                    ClipToBounds="True">
                <Grid>
                    <!-- Carousel background gradient -->
                    <Border CornerRadius="12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#126C5CE7" Offset="0"/>
                                <GradientStop Color="#084A6CF7" Offset="0.5"/>
                                <GradientStop Color="#12F5C518" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Section label -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#20F5C518" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="📢 LATEST NEWS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGoldBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding InstalledVersionText}" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- Scrolling patch notes content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Hero area -->
                                <Border CornerRadius="10" Margin="0,0,0,16" Height="180"
                                        ClipToBounds="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A3E" Offset="0"/>
                                            <GradientStop Color="#2D1B4E" Offset="0.3"/>
                                            <GradientStop Color="#3D1942" Offset="0.6"/>
                                            <GradientStop Color="#1A2A4E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <!-- Decorative glow -->
                                        <Ellipse Width="200" Height="200" Opacity="0.12"
                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,-50,-40,0">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="{StaticResource AccentGold}" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse Width="160" Height="160" Opacity="0.08"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                 Margin="-30,0,0,-30">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="{StaticResource GlowPurple}" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Banner text -->
                                        <StackPanel VerticalAlignment="Center" Margin="28,0">
                                            <TextBlock Text="TOYBATTLES" FontSize="32" FontWeight="ExtraBold"
                                                       Foreground="White" FontFamily="Segoe UI">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                                      Color="{StaticResource AccentGold}" Opacity="0.4"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <TextBlock Text="MicroVolts Recharged" FontSize="14"
                                                       FontWeight="Light" Foreground="#8892B0" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding RemoteVersionText}" FontSize="11"
                                                       Foreground="#5A6A90" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Patch notes text -->
                                <TextBlock Text="{Binding PatchNotes}"
                                           FontSize="13" LineHeight="22"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== LINKS PANEL (right side) ===== -->
            <StackPanel Grid.Column="1">
                <!-- Links header -->
                <TextBlock Text="L I N K S" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- Discord -->
                <Button Style="{StaticResource LinkCardButton}" Margin="0,0,0,8"
                        Command="{Binding DataContext.NavigateDiscordCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DISCORD" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Join our community" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#20F5C518" CornerRadius="8"
                                Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="💬" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Website -->
                <Button Style="{StaticResource LinkCardButton}" Margin="0,0,0,8"
                        Command="{Binding DataContext.NavigateNewsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="WEBSITE" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Visit toybattles.net" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#20F5C518" CornerRadius="8"
                                Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="🌐" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Register -->
                <Button Style="{StaticResource LinkCardButton}" Margin="0,0,0,8"
                        Command="{Binding DataContext.NavigateNewsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="REGISTER" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Create an account" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#20F5C518" CornerRadius="8"
                                Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>

                <!-- Repair shortcut -->
                <Button Style="{StaticResource LinkCardButton}" Margin="0,12,0,0"
                        Command="{Binding DataContext.NavigateRepairCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="REPAIR" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Verify game files" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#206C5CE7" CornerRadius="8"
                                Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="🔧" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== PROGRESS BAR AREA ===== -->
        <StackPanel Grid.Row="1"
                    Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,12">
            <ProgressBar Value="{Binding ProgressPercent}"
                         Minimum="0" Maximum="100"
                         Style="{StaticResource AccentProgressBar}"
                         Margin="0,0,0,6"/>
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding DownloadSpeed}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,14,0"
                               Visibility="{Binding DownloadSpeed, Converter={StaticResource StringToVis}}"/>
                    <TextBlock Text="{Binding Eta}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Visibility="{Binding Eta, Converter={StaticResource StringToVis}}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- ===== BOTTOM: Status + PLAY BUTTON ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status text (left) -->
            <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"/>

            <!-- PLAY button (right) -->
            <Button Grid.Column="1"
                    Content="{Binding ActionButtonText}"
                    Command="{Binding ActionCommand}"
                    IsEnabled="{Binding IsActionEnabled}"
                    Style="{StaticResource PlayButton}"
                    MinWidth="220"/>
        </Grid>
    </Grid>
</UserControl>
