<Window x:Class="Launcher.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Launcher.App.ViewModels"
        xmlns:views="clr-namespace:Launcher.App.Views"
        xmlns:conv="clr-namespace:Launcher.App.Converters"
        Title="ToyBattles Launcher"
        Width="1020" Height="640"
        MinWidth="900" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <conv:NavSelectionConverter x:Key="NavSelect"/>

        <!-- Data templates for page content -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RepairViewModel}">
            <views:RepairView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer border with rounded corners and shadow -->
    <Border CornerRadius="14"
            Background="{StaticResource BgDarkestBrush}"
            BorderBrush="#18FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== TOP NAV BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgNavBarBrush}"
                    CornerRadius="14,14,0,0"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Glow dot -->
                        <Grid Margin="0,0,10,0">
                            <Ellipse Width="8" Height="8" Opacity="0.5">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{StaticResource AccentGold}"/>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="8"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse Width="8" Height="8">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{StaticResource AccentGold}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <TextBlock Text="TOY" FontSize="18" FontWeight="ExtraBold"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="BATTLES" FontSize="18" FontWeight="ExtraBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Center Nav Items -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Command="{Binding NavigateHomeCommand}"
                                Style="{StaticResource NavButton}"
                                Content="HOME" Margin="4,0"/>
                        <Button Command="{Binding NavigateNewsCommand}"
                                Style="{StaticResource NavButton}"
                                Content="NEWS" Margin="4,0"/>
                        <Button Command="{Binding NavigateRepairCommand}"
                                Style="{StaticResource NavButton}"
                                Content="REPAIR" Margin="4,0"/>
                        <Button Command="{Binding NavigateSettingsCommand}"
                                Style="{StaticResource NavButton}"
                                Content="SETTINGS" Margin="4,0"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding MinimizeCommand}"
                                Content="─" FontSize="11"
                                Width="32" Height="28"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding CloseCommand}"
                                Content="✕" FontSize="11"
                                Width="32" Height="28"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#44FF4757"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== CONTENT AREA ===== -->
            <Border Grid.Row="1"
                    CornerRadius="0,0,14,14"
                    ClipToBounds="True">
                <Grid>
                    <!-- Ambient glow in background -->
                    <Ellipse Width="500" Height="500" Opacity="0.04"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-100,-100,0" IsHitTestVisible="False">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{StaticResource GlowPurple}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="400" Height="400" Opacity="0.03"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-100,0,0,-50" IsHitTestVisible="False">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{StaticResource AccentGold}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Page content -->
                    <ContentControl Content="{Binding CurrentPage}" Margin="24,20"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
