<Window x:Class="Launcher.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Launcher.App.ViewModels"
        xmlns:views="clr-namespace:Launcher.App.Views"
        xmlns:conv="clr-namespace:Launcher.App.Converters"
        Title="ToyBattles Launcher"
        Width="1040" Height="650"
        MinWidth="920" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <conv:NavSelectionConverter x:Key="NavSelect"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RepairViewModel}">
            <views:RepairView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer shell with rounded corners and drop shadow -->
    <Border CornerRadius="16"
            Background="{StaticResource BgDarkestBrush}"
            BorderBrush="#10FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" ShadowDepth="0" Color="#000000" Opacity="0.88"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Icon-only sidebar -->
                <ColumnDefinition Width="72"/>
                <!-- Full-bleed content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ==================== LEFT SIDEBAR ==================== -->
            <Border Grid.Column="0"
                    Background="#06060E"
                    CornerRadius="16,0,0,16"
                    BorderBrush="#08FFFFFF"
                    BorderThickness="0,0,1,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72"/>   <!-- Logo -->
                        <RowDefinition Height="*"/>    <!-- Nav items -->
                        <RowDefinition Height="Auto"/> <!-- Window controls -->
                    </Grid.RowDefinitions>

                    <!-- Logo / Home button -->
                    <Button Grid.Row="0"
                            Command="{Binding NavigateHomeCommand}"
                            Background="Transparent" BorderThickness="0"
                            Width="72" Height="72" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <Grid>
                                        <!-- Logo image (loaded at runtime from Assets/logo.png) -->
                                        <Image x:Name="LogoImage"
                                               Width="46" Height="46"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="Collapsed"/>
                                        <!-- Text fallback (shown when no logo image) -->
                                        <TextBlock x:Name="LogoTextFallback"
                                                   FontSize="20" FontWeight="ExtraBold"
                                                   FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <Run Text="T" Foreground="{StaticResource AccentBlueBrush}"/>
                                            <Run Text="B" Foreground="{StaticResource AccentGoldBrush}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#08FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,12,0,0">

                        <!-- HOME -->
                        <Button Command="{Binding NavigateHomeCommand}"
                                Style="{StaticResource SideNavButton}"
                                ToolTip="Home">
                            <Grid Width="72" Height="60">
                                <!-- Left accent bar -->
                                <Border Width="3" Height="30"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        CornerRadius="0,3,3,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Home}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <!-- Icon background pill -->
                                <Border Width="44" Height="44" CornerRadius="12"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Home}" Value="True">
                                                    <Setter Property="Background" Value="#1426C0F0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <!-- Home icon -->
                                <TextBlock Text="&#xE80F;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#28304A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Home}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>

                        <!-- REPAIR -->
                        <Button Command="{Binding NavigateRepairCommand}"
                                Style="{StaticResource SideNavButton}"
                                ToolTip="Repair">
                            <Grid Width="72" Height="60">
                                <!-- Left accent bar -->
                                <Border Width="3" Height="30"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        CornerRadius="0,3,3,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Repair}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <!-- Icon background pill -->
                                <Border Width="44" Height="44" CornerRadius="12"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Repair}" Value="True">
                                                    <Setter Property="Background" Value="#1426C0F0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <!-- Repair icon -->
                                <TextBlock Text="&#xE90F;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#28304A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Repair}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>

                    </StackPanel>

                    <!-- Window Controls (bottom of sidebar) -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center"
                                Margin="0,0,0,18">

                        <!-- Minimize -->
                        <Button Command="{Binding MinimizeCommand}"
                                Width="38" Height="38" Cursor="Hand"
                                Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="10">
                                        <TextBlock Text="&#xE921;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="#28304A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#0AFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Close -->
                        <Button Command="{Binding CloseCommand}"
                                Width="38" Height="38" Cursor="Hand"
                                Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="10">
                                        <TextBlock Text="&#xE8BB;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="#28304A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#44FF4757"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== MAIN CONTENT AREA ==================== -->
            <Border Grid.Column="1" CornerRadius="0,16,16,0" ClipToBounds="True">
                <Grid>

                    <!-- Background: wallpaper slideshow -->
                    <!-- Layer A -->
                    <Image x:Name="WallpaperA" Stretch="UniformToFill" Opacity="1"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Layer B (crossfades over A) -->
                    <Image x:Name="WallpaperB" Stretch="UniformToFill" Opacity="0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Fallback / tint overlay for when no wallpapers are loaded -->
                    <Rectangle IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C0080D14" Offset="0"/>
                                <GradientStop Color="#B01A0A28" Offset="0.5"/>
                                <GradientStop Color="#C00B0E22" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ===== ANIMATED BACKGROUND ORBS ===== -->
                    <Grid IsHitTestVisible="False">

                        <!-- Orb 1: Brand Blue — top right -->
                        <Ellipse x:Name="OrbRed"
                                 Width="680" Height="680"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,-240,-180,0"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.06">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#26C0F0" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.04" To="0.10"
                                                             Duration="0:0:5.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.88" To="1.12"
                                                             Duration="0:0:5.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.88" To="1.12"
                                                             Duration="0:0:5.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Orb 2: Blue — bottom left -->
                        <Ellipse x:Name="OrbBlue"
                                 Width="520" Height="520"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Margin="-120,0,0,-120"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.05">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#2860FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True"
                                                    BeginTime="0:0:2">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.03" To="0.08"
                                                             Duration="0:0:7">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.90" To="1.10"
                                                             Duration="0:0:7">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.90" To="1.10"
                                                             Duration="0:0:7">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Orb 3: Brand Gold — mid right -->
                        <Ellipse x:Name="OrbPurple"
                                 Width="320" Height="320"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,-40,60"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.04">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFB800" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True"
                                                    BeginTime="0:0:1">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.02" To="0.07"
                                                             Duration="0:0:4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.85" To="1.15"
                                                             Duration="0:0:4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.85" To="1.15"
                                                             Duration="0:0:4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Orb 4: Cyan — top left accent -->
                        <Ellipse x:Name="OrbCyan"
                                 Width="200" Height="200"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Margin="40,30,0,0"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.03">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#00C8FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True"
                                                    BeginTime="0:0:3">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.01" To="0.05"
                                                             Duration="0:0:6">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.80" To="1.20"
                                                             Duration="0:0:6">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.80" To="1.20"
                                                             Duration="0:0:6">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                    </Grid>

                    <!-- ===== FLOATING PARTICLES ===== -->
                    <views:ParticleCanvas/>

                    <!-- Bottom vignette: dark gradient overlay for text legibility -->
                    <Rectangle VerticalAlignment="Bottom" Height="300"
                               IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC080810" Offset="0.6"/>
                                <GradientStop Color="#F0080810" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Thin top drag region -->
                    <Border Height="44" VerticalAlignment="Top"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            IsHitTestVisible="True"/>

                    <!-- Current page view (transparent overlay) -->
                    <ContentControl Content="{Binding CurrentPage}"/>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
