<Window x:Class="Launcher.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Launcher.App.ViewModels"
        xmlns:views="clr-namespace:Launcher.App.Views"
        xmlns:conv="clr-namespace:Launcher.App.Converters"
        Title="ToyBattles Launcher"
        Width="1080" Height="690"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <conv:NavSelectionConverter x:Key="NavSelect"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RepairViewModel}">
            <views:RepairView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
    <!-- Shadow layer — Margin gives the shadow room to spread, avoiding the rectangular box-outline artifact -->
    <Border CornerRadius="16" Margin="20"
            Background="{StaticResource BgDarkestBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#000000" Opacity="0.88"/>
        </Border.Effect>
    </Border>

    <!-- Content layer, clipped to rounded rectangle -->
    <Border CornerRadius="16" Margin="20"
            Background="{StaticResource BgDarkestBrush}"
            BorderBrush="#10FFFFFF"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid x:Name="InnerGrid">
            <Grid.ColumnDefinitions>
                <!-- Icon-only sidebar -->
                <ColumnDefinition Width="72"/>
                <!-- Full-bleed content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ==================== LEFT SIDEBAR ==================== -->
            <Border Grid.Column="0"
                    Background="#06060E"
                    CornerRadius="16,0,0,16"
                    BorderBrush="#08FFFFFF"
                    BorderThickness="0,0,1,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72"/>   <!-- Logo -->
                        <RowDefinition Height="*"/>    <!-- Nav items -->
                        <RowDefinition Height="Auto"/> <!-- Window controls -->
                    </Grid.RowDefinitions>

                    <!-- Logo / Banner button -->
                    <Button Grid.Row="0"
                            Command="{Binding ShowBannerCommand}"
                            Background="Transparent" BorderThickness="0"
                            Width="72" Height="72" Cursor="Hand"
                            ToolTip="ToyBattles">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent"
                                        CornerRadius="0,0,0,0">
                                    <Grid>
                                        <!-- Active indicator bar (left edge, shown in banner mode) -->
                                        <Border x:Name="activeBar" Width="3" Height="30"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                CornerRadius="0,3,3,0" Opacity="0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="{StaticResource AccentBlue}" Offset="0"/>
                                                    <GradientStop Color="{StaticResource AccentGold}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Logo image (loaded at runtime from Assets/logo.png) -->
                                        <Image x:Name="LogoImage"
                                               Width="46" Height="46"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="Collapsed"/>
                                        <!-- Text fallback (shown when no logo image) -->
                                        <TextBlock x:Name="LogoTextFallback"
                                                   FontSize="20" FontWeight="ExtraBold"
                                                   FontFamily="Segoe UI"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <Run Text="T" Foreground="{StaticResource AccentBlueBrush}"/>
                                            <Run Text="B" Foreground="{StaticResource AccentGoldBrush}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#0C26C0F0"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Banner}" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#1426C0F0"/>
                                        <Setter TargetName="activeBar" Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,12,0,0">

                        <!-- HOME -->
                        <Button Command="{Binding NavigateHomeCommand}"
                                Style="{StaticResource SideNavButton}"
                                ToolTip="Home">
                            <Grid Width="72" Height="60">
                                <!-- Left accent bar -->
                                <Border Width="3" Height="30"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        CornerRadius="0,3,3,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Home}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <!-- Icon background pill -->
                                <Border Width="44" Height="44" CornerRadius="12"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Home}" Value="True">
                                                    <Setter Property="Background" Value="#1426C0F0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <!-- Home icon -->
                                <TextBlock Text="&#xE80F;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#28304A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNav, Converter={StaticResource NavSelect}, ConverterParameter=Home}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Button>

                    </StackPanel>

                    <!-- Window Controls (bottom of sidebar) -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center"
                                Margin="0,0,0,18">

                        <!-- Minimize -->
                        <Button Command="{Binding MinimizeCommand}"
                                Width="38" Height="38" Cursor="Hand"
                                Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="10">
                                        <TextBlock Text="&#xE921;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="#28304A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#0AFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Close -->
                        <Button Command="{Binding CloseCommand}"
                                Width="38" Height="38" Cursor="Hand"
                                Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="Transparent" CornerRadius="10">
                                        <TextBlock Text="&#xE8BB;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="#28304A"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#44FF4757"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== MAIN CONTENT AREA ==================== -->
            <Border Grid.Column="1" CornerRadius="0,16,16,0" ClipToBounds="True">
                <Grid x:Name="ContentGrid">

                    <!-- Background: wallpaper slideshow -->
                    <!-- Layer A -->
                    <Image x:Name="WallpaperA" Stretch="UniformToFill" Opacity="1"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Layer B (crossfades over A) -->
                    <Image x:Name="WallpaperB" Stretch="UniformToFill" Opacity="0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Theme tint overlay (transparent normally, coloured for seasonal builds) -->
                    <Rectangle IsHitTestVisible="False"
                               Fill="{StaticResource WallpaperTintBrush}"/>
                    <!-- Fallback / tint overlay for when no wallpapers are loaded -->
                    <Rectangle IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C0080D14" Offset="0"/>
                                <GradientStop Color="#B01A0A28" Offset="0.5"/>
                                <GradientStop Color="#C00B0E22" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ===== ANIMATED BACKGROUND ORBS ===== -->
                    <Grid IsHitTestVisible="False">

                        <!-- Orb 1: Brand Blue — top right -->
                        <Ellipse x:Name="OrbRed"
                                 Width="680" Height="680"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,-240,-180,0"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.06">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#26C0F0" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.04" To="0.10"
                                                             Duration="0:0:5.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.88" To="1.12"
                                                             Duration="0:0:5.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.88" To="1.12"
                                                             Duration="0:0:5.5">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Orb 2: Blue — bottom left -->
                        <Ellipse x:Name="OrbBlue"
                                 Width="520" Height="520"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Margin="-120,0,0,-120"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.05">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#2860FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True"
                                                    BeginTime="0:0:2">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.03" To="0.08"
                                                             Duration="0:0:7">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.90" To="1.10"
                                                             Duration="0:0:7">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.90" To="1.10"
                                                             Duration="0:0:7">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Orb 3: Brand Gold — mid right -->
                        <Ellipse x:Name="OrbPurple"
                                 Width="320" Height="320"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,-40,60"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.04">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFB800" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True"
                                                    BeginTime="0:0:1">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.02" To="0.07"
                                                             Duration="0:0:4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.85" To="1.15"
                                                             Duration="0:0:4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.85" To="1.15"
                                                             Duration="0:0:4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Orb 4: Cyan — top left accent -->
                        <Ellipse x:Name="OrbCyan"
                                 Width="200" Height="200"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Margin="40,30,0,0"
                                 RenderTransformOrigin="0.5,0.5"
                                 Opacity="0.03">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#00C8FF" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True"
                                                    BeginTime="0:0:3">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.01" To="0.05"
                                                             Duration="0:0:6">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             From="0.80" To="1.20"
                                                             Duration="0:0:6">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             From="0.80" To="1.20"
                                                             Duration="0:0:6">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                    </Grid>

                    <!-- ===== FLOATING PARTICLES ===== -->
                    <views:ParticleCanvas/>

                    <!-- Bottom vignette: dark gradient overlay for text legibility -->
                    <Rectangle VerticalAlignment="Bottom" Height="300"
                               IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC080810" Offset="0.6"/>
                                <GradientStop Color="#F0080810" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Full-area drag region (below ContentControl so interactive elements still work) -->
                    <Border Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            IsHitTestVisible="True"/>

                    <!-- Current page view (transparent overlay) -->
                    <ContentControl Content="{Binding CurrentPage}"/>

                    <!-- ===== BANNER MODE OVERLAY ===== -->
                    <Border x:Name="BannerOverlay"
                            MouseLeftButtonDown="BannerOverlay_MouseLeftButtonDown"
                            Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBannerMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#D0020408" Offset="0"/>
                                <GradientStop Color="#E0060912" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <!-- Staff Team content -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Center">
                            <StackPanel Margin="60,28,60,20">

                                <!-- Header -->
                                <TextBlock Text="STAFF TEAM" FontSize="32" FontWeight="ExtraBold"
                                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                                           Margin="0,0,0,4">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#26C0F0" Offset="0"/>
                                            <GradientStop Color="#FFB800" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                                                          Color="#26C0F0" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <TextBlock Text="MicroVolts Recharged"
                                           FontSize="13" FontFamily="Segoe UI" FontWeight="Light"
                                           Foreground="#2A3A5A"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,18"/>

                                <!-- Separator -->
                                <Border Height="1" Margin="100,0,100,18">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#2026C0F0" Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Staff cards: 2-column grid -->
                                <UniformGrid Columns="2" Rows="2">

                                    <!-- ADMIN -->
                                    <Border Margin="6" Padding="18,14" CornerRadius="10"
                                            Background="#0C16a12b" BorderBrush="#2516a12b" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Border Width="3" CornerRadius="2" Margin="0,0,10,0">
                                                    <Border.Background><SolidColorBrush Color="#16a12b"/></Border.Background>
                                                </Border>
                                                <TextBlock Text="ADMIN" FontSize="10" FontWeight="Bold"
                                                           Foreground="#16a12b" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Mikael"    FontSize="13" FontFamily="Segoe UI" Foreground="#7AAA88" Margin="13,0,0,3"/>
                                            <TextBlock Text="Template"  FontSize="13" FontFamily="Segoe UI" Foreground="#7AAA88" Margin="13,0,0,3"/>
                                            <TextBlock Text="avlad171"  FontSize="13" FontFamily="Segoe UI" Foreground="#7AAA88" Margin="13,0,0,3"/>
                                            <TextBlock Text="mnml"      FontSize="13" FontFamily="Segoe UI" Foreground="#7AAA88" Margin="13,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- GAME MASTER -->
                                    <Border Margin="6" Padding="18,14" CornerRadius="10"
                                            Background="#0Cf29b22" BorderBrush="#25f29b22" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Border Width="3" CornerRadius="2" Margin="0,0,10,0">
                                                    <Border.Background><SolidColorBrush Color="#f29b22"/></Border.Background>
                                                </Border>
                                                <TextBlock Text="GAME MASTER" FontSize="10" FontWeight="Bold"
                                                           Foreground="#f29b22" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="kierababyy" FontSize="13" FontFamily="Segoe UI" Foreground="#B8955A" Margin="13,0,0,3"/>
                                            <TextBlock Text="Scayla"     FontSize="13" FontFamily="Segoe UI" Foreground="#B8955A" Margin="13,0,0,3"/>
                                            <TextBlock Text="Mumnum"     FontSize="13" FontFamily="Segoe UI" Foreground="#B8955A" Margin="13,0,0,3"/>
                                            <TextBlock Text="kTs"        FontSize="13" FontFamily="Segoe UI" Foreground="#B8955A" Margin="13,0,0,3"/>
                                            <TextBlock Text="mew"        FontSize="13" FontFamily="Segoe UI" Foreground="#B8955A" Margin="13,0,0,3"/>
                                            <TextBlock Text="zScopion"   FontSize="13" FontFamily="Segoe UI" Foreground="#B8955A" Margin="13,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- MODERATOR -->
                                    <Border Margin="6" Padding="18,14" CornerRadius="10"
                                            Background="#0Ce91eae" BorderBrush="#25e91eae" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Border Width="3" CornerRadius="2" Margin="0,0,10,0">
                                                    <Border.Background><SolidColorBrush Color="#e91eae"/></Border.Background>
                                                </Border>
                                                <TextBlock Text="MODERATOR" FontSize="10" FontWeight="Bold"
                                                           Foreground="#e91eae" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="VACANT" FontSize="13" FontFamily="Segoe UI"
                                                       Foreground="#4A3040" FontStyle="Italic" Margin="13,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- TRIAL MODERATOR -->
                                    <Border Margin="6" Padding="18,14" CornerRadius="10"
                                            Background="#0Cdb799a" BorderBrush="#25db799a" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Border Width="3" CornerRadius="2" Margin="0,0,10,0">
                                                    <Border.Background><SolidColorBrush Color="#db799a"/></Border.Background>
                                                </Border>
                                                <TextBlock Text="TRIAL MODERATOR" FontSize="10" FontWeight="Bold"
                                                           Foreground="#db799a" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="VACANT" FontSize="13" FontFamily="Segoe UI"
                                                       Foreground="#4A3040" FontStyle="Italic" Margin="13,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>

                                <!-- Back button -->
                                <Button Command="{Binding NavigateHomeCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Center"
                                        Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72B;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Back to Home"
                                                   FontFamily="Segoe UI" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </Border>

        </Grid>
    </Border>
    </Grid>
</Window>
