<UserControl x:Class="Launcher.App.Views.LeaderboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Launcher.App.Views"
             xmlns:vm="clr-namespace:Launcher.App.ViewModels"
             xmlns:conv="clr-namespace:Launcher.App.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>
        <conv:DdsLevelIconConverter x:Key="DdsLevelIconConverter"/>
        <!-- Visibility converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Single Column Leaderboard -->
        <Border Background="#A0080D14" CornerRadius="12" BorderBrush="#2026C0F0" BorderThickness="1" Padding="12,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header with Toggle -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="{Binding HeaderTitle}" FontSize="16" FontWeight="Black" Foreground="#26C0F0" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    
                    <Button Grid.Column="1" Command="{Binding ToggleViewCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#707A8A" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
                
                <!-- Players List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              Visibility="{Binding IsShowingPlayers, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding TopPlayers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#40141926" CornerRadius="6" Margin="0,0,0,4" Padding="8,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Rank -->
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" FontWeight="Black" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#707A8A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Rank}" Value="1">
                                                            <Setter Property="Foreground" Value="#FFD700"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#FFD700" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Rank}" Value="2">
                                                            <Setter Property="Foreground" Value="#C0C0C0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Rank}" Value="3">
                                                            <Setter Property="Foreground" Value="#CD7F32"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Level Icon -->
                                        <Image Grid.Column="1" 
                                               Source="{Binding Level, Converter={StaticResource DdsLevelIconConverter}}" 
                                               Width="18" Height="18" 
                                               HorizontalAlignment="Left" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <!-- Name -->
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Clans List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsShowingPlayers}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding TopClans}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#40141926" CornerRadius="6" Margin="0,0,0,4" Padding="8,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Rank -->
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" FontWeight="Black" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#707A8A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Rank}" Value="1">
                                                            <Setter Property="Foreground" Value="#FFD700"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#FFD700" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Rank}" Value="2">
                                                            <Setter Property="Foreground" Value="#C0C0C0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Rank}" Value="3">
                                                            <Setter Property="Foreground" Value="#CD7F32"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Clan Icon Placeholder -->
                                        <TextBlock Grid.Column="1" Text="&#xEA3A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2ECC71" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        <!-- Name -->
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
