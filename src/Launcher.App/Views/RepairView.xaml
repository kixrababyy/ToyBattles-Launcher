<UserControl x:Class="Launcher.App.Views.RepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Launcher.App.Converters"
             Loaded="RepairView_Loaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4"/>
            <ThicknessAnimation Storyboard.TargetName="RootPanel"
                                Storyboard.TargetProperty="Margin"
                                From="0,16,0,0" To="0"
                                Duration="0:0:0.4"/>
        </Storyboard>
    </UserControl.Resources>

    <StackPanel x:Name="RootPanel" Opacity="0">
        <!-- Header -->
        <TextBlock Text="Verify &amp; Repair" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
        <TextBlock Text="Check your game files for corruption or missing data."
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,24"/>

        <!-- Repair Card -->
        <Border Style="{StaticResource GlowCard}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="{Binding StatusText}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Progress -->
                <StackPanel Visibility="{Binding IsRepairing, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,16">
                    <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                                 Style="{StaticResource AccentProgressBar}"/>
                </StackPanel>

                <!-- Results -->
                <Border Visibility="{Binding ResultSummary, Converter={StaticResource StringToVis}}"
                        Background="{StaticResource BgMediumBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        BorderBrush="#10FFFFFF" BorderThickness="1">
                    <TextBlock Text="{Binding ResultSummary}" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="22"/>
                </Border>

                <Button Content="Verify &amp; Repair Files"
                        Command="{Binding RepairCommand}"
                        IsEnabled="{Binding IsRepairEnabled}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
