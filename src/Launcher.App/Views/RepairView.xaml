<UserControl x:Class="Launcher.App.Views.RepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Launcher.App.Converters"
             Background="Transparent"
             Loaded="RepairView_Loaded">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="StringToVis"/>

        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="RootPanel"
                                Storyboard.TargetProperty="Margin"
                                From="36,48,36,0" To="36,24,36,0"
                                Duration="0:0:0.45">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Panel card overlaying the game background -->
        <StackPanel x:Name="RootPanel"
                    Opacity="0"
                    Margin="36,24,36,0"
                    VerticalAlignment="Top"
                    MaxWidth="520"
                    HorizontalAlignment="Left">

            <!-- Card background -->
            <Border Background="#D80C0C1A"
                    CornerRadius="16"
                    BorderBrush="#12FFFFFF"
                    BorderThickness="1"
                    Padding="28,24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0"
                                      Color="#000000" Opacity="0.60"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Verify &amp; Repair"
                                   FontSize="22" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Check your game files for corruption or missing data."
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="#08FFFFFF" Margin="0,0,0,20"/>

                    <!-- Status text -->
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="13" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Progress bar + current file (when repairing) -->
                    <StackPanel Visibility="{Binding IsRepairing, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,16">
                        <ProgressBar Value="{Binding ProgressPercent}"
                                     Minimum="0" Maximum="100"
                                     Style="{StaticResource AccentProgressBar}"/>
                        <TextBlock Text="{Binding CurrentFileText}"
                                   FontSize="11" FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding CurrentFileText, Converter={StaticResource StringToVis}}"/>
                    </StackPanel>

                    <!-- Results summary -->
                    <Border Visibility="{Binding ResultSummary, Converter={StaticResource StringToVis}}"
                            Background="#0CFFFFFF"
                            CornerRadius="10" Padding="16,14"
                            Margin="0,0,0,16"
                            BorderBrush="#0EFFFFFF" BorderThickness="1">
                        <TextBlock Text="{Binding ResultSummary}"
                                   FontSize="13" FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </Border>

                    <!-- Action buttons -->
                    <WrapPanel>
                        <Button Content="Verify &amp; Repair Files"
                                Command="{Binding RepairCommand}"
                                IsEnabled="{Binding IsRepairEnabled}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Full Reinstall"
                                Command="{Binding FullReinstallCommand}"
                                IsEnabled="{Binding IsReinstallEnabled}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Clear Cache"
                                Command="{Binding ClearCacheCommand}"
                                IsEnabled="{Binding IsRepairEnabled}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,8"/>
                        <Button Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsRepairing, Converter={StaticResource BoolToVis}}"/>
                    </WrapPanel>

                    <!-- Cache size feedback -->
                    <TextBlock Text="{Binding CacheSizeText}"
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,6,0,0"
                               Visibility="{Binding CacheSizeText, Converter={StaticResource StringToVis}}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
